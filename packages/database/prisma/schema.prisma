// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE: Tenant & Auth
// ============================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  document  String?  @db.VarChar(20) // CNPJ
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(255)
  logo      String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  customers          Customer[]
  suppliers          Supplier[]
  products           Product[]
  productCategories  ProductCategory[]
  quotes             Quote[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  stockItems         StockItem[]
  stockMovements     StockMovement[]
  productionOrders   ProductionOrder[]
  financialCategories FinancialCategory[]
  financialTransactions FinancialTransaction[]
  shipmentOrders     ShipmentOrder[]
  employees          Employee[]
  opportunities      Opportunity[]
  auditLogs          AuditLog[]

  @@map("tenants")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  name           String   @db.VarChar(255)
  email          String   @db.VarChar(255)
  passwordHash   String   @db.Text
  role           UserRole @default(OPERATOR)
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  auditLogs     AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  SELLER
  OPERATOR
  VIEWER
}

// ============================================
// CRM: Customers & Suppliers
// ============================================

model Customer {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  type         PersonType   @default(JURIDICA)
  name         String       @db.VarChar(255)
  tradeName    String?      @db.VarChar(255) // Nome fantasia
  document     String?      @db.VarChar(20)  // CPF ou CNPJ
  stateReg     String?      @db.VarChar(20)  // Inscrição Estadual
  email        String?      @db.VarChar(255)
  phone        String?      @db.VarChar(20)
  mobile       String?      @db.VarChar(20)
  website      String?      @db.VarChar(255)
  // Address
  zipCode      String?      @db.VarChar(10)
  street       String?      @db.VarChar(255)
  number       String?      @db.VarChar(20)
  complement   String?      @db.VarChar(100)
  neighborhood String?      @db.VarChar(100)
  city         String?      @db.VarChar(100)
  state        String?      @db.VarChar(2)
  // Meta
  notes        String?      @db.Text
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotes      Quote[]
  salesOrders SalesOrder[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([tenantId, document])
  @@map("customers")
}

model Opportunity {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @db.Uuid
  customerId        String?           @db.Uuid
  sellerId          String            @db.Uuid // Vendedor responsável
  name              String            @db.VarChar(255)
  value             Decimal           @default(0) @db.Decimal(12, 2)
  probability       Int               @default(50) // 0-100
  status            OpportunityStatus @default(CONTATO_INICIAL)
  lastInteractionAt DateTime          @default(now())
  closedAt          DateTime?
  notes             String?           @db.Text
  tags              String[]          @default([])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  seller   User      @relation(fields: [sellerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, sellerId])
  @@map("opportunities")
}

enum OpportunityStatus {
  LEAD_QUALIFICADO
  CONTATO_INICIAL
  APRESENTACAO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  FECHADO_GANHO
  FECHADO_PERDIDO
}

model Supplier {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  type         PersonType @default(JURIDICA)
  name         String     @db.VarChar(255)
  tradeName    String?    @db.VarChar(255)
  document     String?    @db.VarChar(20)
  stateReg     String?    @db.VarChar(20)
  email        String?    @db.VarChar(255)
  phone        String?    @db.VarChar(20)
  mobile       String?    @db.VarChar(20)
  website      String?    @db.VarChar(255)
  // Address
  zipCode      String?    @db.VarChar(10)
  street       String?    @db.VarChar(255)
  number       String?    @db.VarChar(20)
  complement   String?    @db.VarChar(100)
  neighborhood String?    @db.VarChar(100)
  city         String?    @db.VarChar(100)
  state        String?    @db.VarChar(2)
  // Meta
  notes        String?    @db.Text
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@index([tenantId, document])
  @@map("suppliers")
}

enum PersonType {
  FISICA
  JURIDICA
}

// ============================================
// PRODUCTS: Catalog & Variants
// ============================================

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String   @db.VarChar(255)
  parentId  String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ProductCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @db.Uuid
  categoryId   String?         @db.Uuid
  sku          String          @db.VarChar(50)
  name         String          @db.VarChar(255)
  description  String?         @db.Text
  type         ProductType     @default(SIMPLE)
  unit         String          @default("UN") @db.VarChar(10) // UN, M, KG, etc.
  costPrice    Decimal         @default(0) @db.Decimal(12, 2)
  salePrice    Decimal         @default(0) @db.Decimal(12, 2)
  minStock     Decimal         @default(0) @db.Decimal(12, 3)
  maxStock     Decimal?        @db.Decimal(12, 3)
  weight       Decimal?        @db.Decimal(10, 3)
  // Configurator (CTO)
  isConfigurable Boolean       @default(false)
  configOptions  Json?         @db.JsonB // Opções de configuração (tecido, cor, gola, etc.)
  bomTemplate    Json?         @db.JsonB // Bill of Materials template
  // Meta
  images       String[]        @default([])
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  quoteItems QuoteItem[]
  salesOrderItems SalesOrderItem[]
  stockItems StockItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  name       String   @db.VarChar(255) // Ex: "Camiseta Azul M"
  sku        String   @db.VarChar(50)
  attributes Json     @db.JsonB // { color: "Azul", size: "M" }
  costPrice  Decimal  @default(0) @db.Decimal(12, 2)
  salePrice  Decimal  @default(0) @db.Decimal(12, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

enum ProductType {
  SIMPLE      // Produto simples (brinde)
  CONFIGURABLE // Produto configurável (CTO - confecção)
  RAW_MATERIAL // Matéria-prima
  SERVICE      // Serviço (personalização, bordado)
}

// ============================================
// SALES: Quotes & Orders
// ============================================

model Quote {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  customerId   String      @db.Uuid
  code         String      @db.VarChar(20) // ORC-2026-0001
  status       QuoteStatus @default(DRAFT)
  validUntil   DateTime?
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  discount     Decimal     @default(0) @db.Decimal(12, 2)
  shippingCost Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?     @db.Text
  conditions   String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id])
  items      QuoteItem[]
  salesOrder SalesOrder?

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("quotes")
}

model QuoteItem {
  id            String  @id @default(uuid()) @db.Uuid
  quoteId       String  @db.Uuid
  productId     String  @db.Uuid
  description   String  @db.VarChar(255)
  quantity      Decimal @db.Decimal(12, 3)
  unitPrice     Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  totalPrice    Decimal @db.Decimal(12, 2)
  // Configurator data (CTO)
  configuration Json?   @db.JsonB // Configurações escolhidas pelo vendedor
  bomCost       Decimal? @db.Decimal(12, 2) // Custo BOM calculado
  laborCost     Decimal? @db.Decimal(12, 2) // Custo mão de obra

  // Relations
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model SalesOrder {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  customerId     String           @db.Uuid
  quoteId        String?          @unique @db.Uuid
  code           String           @db.VarChar(20) // PED-2026-0001
  status         SalesOrderStatus @default(PENDING)
  totalAmount    Decimal          @default(0) @db.Decimal(12, 2)
  paymentMethod  String?          @db.VarChar(50)
  paymentTerms   String?          @db.VarChar(100)
  deliveryDate   DateTime?
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer            @relation(fields: [customerId], references: [id])
  quote            Quote?              @relation(fields: [quoteId], references: [id])
  items            SalesOrderItem[]
  productionOrders ProductionOrder[]
  shipmentOrders   ShipmentOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @db.Uuid
  productId   String  @db.Uuid
  description String  @db.VarChar(255)
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  configuration Json? @db.JsonB

  // Relations
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("sales_order_items")
}

enum SalesOrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

// ============================================
// PURCHASING
// ============================================

model PurchaseOrder {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @db.Uuid
  supplierId   String              @db.Uuid
  code         String              @db.VarChar(20) // COM-2026-0001
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Decimal             @default(0) @db.Decimal(12, 2)
  expectedDate DateTime?
  notes        String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Relations
  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier              @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @db.Uuid
  productName String @db.VarChar(255)
  quantity   Decimal @db.Decimal(12, 3)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  // Relations
  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

// ============================================
// STOCK / INVENTORY
// ============================================

model StockItem {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  productId String   @db.Uuid
  location  String   @default("PRINCIPAL") @db.VarChar(100)
  quantity  Decimal  @default(0) @db.Decimal(12, 3)
  reserved  Decimal  @default(0) @db.Decimal(12, 3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, productId, location])
  @@index([tenantId])
  @@map("stock_items")
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @db.Uuid
  productName String            @db.VarChar(255)
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  reference   String?           @db.VarChar(100) // Referência (nº pedido, etc.)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  ENTRY     // Entrada
  EXIT      // Saída
  TRANSFER  // Transferência
  ADJUST    // Ajuste de inventário
  RETURN    // Devolução
}

// ============================================
// PRODUCTION / PCP
// ============================================

model ProductionOrder {
  id            String                @id @default(uuid()) @db.Uuid
  tenantId      String                @db.Uuid
  salesOrderId  String?               @db.Uuid
  code          String                @db.VarChar(20) // OP-2026-0001
  status        ProductionOrderStatus @default(PLANNED)
  priority      Int                   @default(3) // 1=Urgente, 5=Baixa
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // Relations
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  steps      ProductionStep[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("production_orders")
}

model ProductionStep {
  id                String               @id @default(uuid()) @db.Uuid
  productionOrderId String               @db.Uuid
  name              String               @db.VarChar(255) // Ex: "Corte", "Costura", "Acabamento"
  sequence          Int
  status            ProductionStepStatus @default(PENDING)
  estimatedMinutes  Int?
  actualMinutes     Int?
  startedAt         DateTime?
  completedAt       DateTime?
  notes             String?              @db.Text

  // Relations
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  logs            ProductionLog[]

  @@index([productionOrderId])
  @@map("production_steps")
}

model ProductionLog {
  id               String               @id @default(uuid()) @db.Uuid
  stepId           String               @db.Uuid
  type             ProductionLogType
  loggedAt         DateTime             @default(now())
  processedQty     Decimal?             @db.Decimal(12, 3)
  defectQty        Decimal?             @db.Decimal(12, 3)
  defectType       String?              @db.VarChar(100)
  responsibleName  String               @db.VarChar(255)
  notes            String?              @db.Text

  // Relations
  step ProductionStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("production_logs")
}

enum ProductionLogType {
  START
  FINISH
  PAUSE
  RESUME
  DEFECT
}

enum ProductionOrderStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum ProductionStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ============================================
// FINANCIAL
// ============================================

model FinancialCategory {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @db.Uuid
  name      String              @db.VarChar(255)
  type      FinancialType
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Relations
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([tenantId])
  @@map("financial_categories")
}

model FinancialTransaction {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @db.Uuid
  categoryId  String?           @db.Uuid
  type        FinancialType
  description String            @db.VarChar(255)
  amount      Decimal           @db.Decimal(12, 2)
  dueDate     DateTime
  paidDate    DateTime?
  status      TransactionStatus @default(PENDING)
  reference   String?           @db.VarChar(100) // Nº pedido, NF, etc.
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category FinancialCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("financial_transactions")
}

enum FinancialType {
  INCOME   // Receita (contas a receber)
  EXPENSE  // Despesa (contas a pagar)
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// LOGISTICS / SHIPPING
// ============================================

model ShipmentOrder {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  salesOrderId  String         @db.Uuid
  code          String         @db.VarChar(20) // EXP-2026-0001
  status        ShipmentStatus @default(PENDING)
  carrier       String?        @db.VarChar(255)
  trackingCode  String?        @db.VarChar(100)
  shippedAt     DateTime?
  deliveredAt   DateTime?
  // Delivery address
  recipientName String?        @db.VarChar(255)
  zipCode       String?        @db.VarChar(10)
  street        String?        @db.VarChar(255)
  number        String?        @db.VarChar(20)
  complement    String?        @db.VarChar(100)
  neighborhood  String?        @db.VarChar(100)
  city          String?        @db.VarChar(100)
  state         String?        @db.VarChar(2)
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("shipment_orders")
}

enum ShipmentStatus {
  PENDING
  PICKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

// ============================================
// HR: Employees & Payroll
// ============================================

model Employee {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  name         String         @db.VarChar(255)
  document     String?        @db.VarChar(14) // CPF
  email        String?        @db.VarChar(255)
  phone        String?        @db.VarChar(20)
  position     String?        @db.VarChar(100)
  department   String?        @db.VarChar(100)
  admissionDate DateTime?
  salary       Decimal?       @db.Decimal(12, 2)
  status       EmployeeStatus @default(ACTIVE)
  // Address
  zipCode      String?        @db.VarChar(10)
  street       String?        @db.VarChar(255)
  number       String?        @db.VarChar(20)
  complement   String?        @db.VarChar(100)
  neighborhood String?        @db.VarChar(100)
  city         String?        @db.VarChar(100)
  state        String?        @db.VarChar(2)
  notes        String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrolls Payroll[]

  @@index([tenantId])
  @@map("employees")
}

model Payroll {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @db.Uuid
  month       Int      // 1-12
  year        Int
  baseSalary  Decimal  @db.Decimal(12, 2)
  overtime    Decimal  @default(0) @db.Decimal(12, 2)
  deductions  Decimal  @default(0) @db.Decimal(12, 2)
  netSalary   Decimal  @db.Decimal(12, 2)
  paidAt      DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("payrolls")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  action    String   @db.VarChar(100) // Ex: "UPDATE_SALARY", "CREATE_TRANSACTION"
  entity    String   @db.VarChar(100) // Ex: "Employee", "FinancialTransaction"
  entityId  String   @db.Uuid
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@map("audit_logs")
}
