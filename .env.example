# ============================================
# D.job System — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# For app-specific vars, create .env.local inside each app.

# ---- Database (packages/database) ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/djob_dev?schema=public"

# ---- JWT (apps/api) ----
JWT_SECRET="change-this-to-a-random-secret-key"
JWT_EXPIRY="7d"

# ---- API URL (apps/web) ----
# In apps/web/.env.local:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Production URLs ----
# NEXT_PUBLIC_API_URL=https://api.djob.com.br
