# ============================================
# D.job System — Production Environment Variables
# ============================================
# Copy to .env on the Oracle Cloud server

# ---- PostgreSQL ----
POSTGRES_USER=djob
POSTGRES_PASSWORD=       # REQUIRED: generate with `openssl rand -base64 32`
POSTGRES_DB=djob_prod

# ---- API (NestJS) ----
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://djob:${POSTGRES_PASSWORD}@db:5432/djob_prod?schema=public
JWT_SECRET=              # REQUIRED: generate with `openssl rand -base64 64`
JWT_EXPIRY=7d
CORS_ORIGINS=https://app.djob.com.br

# ---- Frontend (Vercel — set in Vercel Dashboard) ----
# NEXT_PUBLIC_API_URL=https://api.djob.com.br
